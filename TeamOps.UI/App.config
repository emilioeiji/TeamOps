<configuration>
	<appSettings>
		<add key="DatabasePath" value="C:\TeamOps\DB\teamops.db" />

		<!-- Diretório onde os PR serão salvos -->
		<add key="PRDirectory" value="C:\TeamOps\PR\" />

		<!-- Caminho do arquivo modelo -->
		<add key="PRTemplate" value="C:\TeamOps\Modelos\ModeloPR.xlsx" />

		<!-- Diretório onde os CL serão salvos -->
		<add key="CLDirectory" value="C:\TeamOps\CL\" />

		<!-- Caminho do arquivo modelo -->
		<add key="CLTemplate" value="C:\TeamOps\Modelos\ModeloCL.xlsx" />

		<!-- Diretório onde os anexos do Hikitsugui serão salvos -->
		<add key="HikitsuguiAttachmentPath" value="C:\TeamOps\Anexo\Hikitsugui\" />

		<!-- Diretório onde ficam os arquivos CSV de schedule -->
		<add key="OperatorScheduleDirectory" value="C:\TeamOps\Schedule\" />

		<!-- Diretório final onde o TeamOps lê os TXT de eventos -->
		<add key="ProductionEventsDirectory" value="C:\TeamOps\Production\Events\" />

		<!-- Diretório de origem dos arquivos de eventos usado pelo BAT -->
		<add key="ProductionSourceEventsDirectory" value="C:\TeamOps\Production\Source\Events\" />

		<!-- Diretório de origem dos arquivos .dat usado pelo BAT -->
		<add key="ProductionSourceDatDirectory" value="C:\TeamOps\Production\Source\Dat\" />

		<!-- BAT responsável por copiar/sincronizar os arquivos antes da importação -->
		<add key="ProductionImportBatchPath" value="C:\TeamOps\Production\import-production.bat" />

		<!-- Arquivo sinalizado pelo BAT quando a cópia terminar -->
		<add key="ProductionImportCompletionFile" value="C:\TeamOps\Production\import.done" />

		<!-- Timeout da execução do BAT em segundos -->
		<add key="ProductionImportTimeoutSeconds" value="180" />
	</appSettings>
</configuration>
